{"episode": "ep001-vairagya", "quote_id": 1, "tradition": "east-lineage", "work": "Bhagavad Gita 2.47–2.48 (Arnold)", "translator": "Edwin Arnold", "verse_or_section": "2.47–2.48", "license": "PD", "citation_url": "https://www.sacred-texts.com/hin/gita/bg02.htm", "fetch_url": "https://www.sacred-texts.com/hin/gita/bg02.htm", "verified_date": "2026-05-08", "quote": "Let right deeds be thy motive, not the fruit which comes from them. And live in action! Labour! Make thine acts thy piety, casting all self aside, contemning gain and merit; equable in good or evil: equability is Yog, is piety!", "turn_idx": 2}
{"episode": "ep001-vairagya", "quote_id": 2, "tradition": "east-lineage", "work": "Bhagavad Gita 2.56–2.57 (Arnold)", "translator": "Edwin Arnold", "verse_or_section": "2.56–2.57", "license": "PD", "citation_url": "https://www.sacred-texts.com/hin/gita/bg02.htm", "fetch_url": "https://www.sacred-texts.com/hin/gita/bg02.htm", "verified_date": "2026-05-08", "quote": "in sorrows not dejected, and in joys not overjoyed; dwelling outside the stress of passion, fear, and anger; fixed in calms of lofty contemplation", "turn_idx": 4}
{"episode": "ep001-vairagya", "quote_id": 3, "tradition": "east-lineage", "work": "Yoga Sūtras 1.15 (Vivekananda)", "translator": "Swami Vivekananda", "verse_or_section": "1.15", "license": "PD", "citation_url": "https://www.sacred-texts.com/hin/yogasutr.htm", "fetch_url": "https://www.sacred-texts.com/hin/yogasutr.htm", "verified_date": "2026-05-08", "quote": "That effect which comes to those who have given up their thirst after objects, either seen or heard, and which wills to control the objects, is non-attachment.", "turn_idx": 6}
{"episode": "ep001-vairagya", "quote_id": 4, "tradition": "east-lineage", "work": "Anguttara Nikāya 6.55 — With Soṇa (Sujato)", "translator": "Bhante Sujato", "verse_or_section": "AN 6.55", "license": "CC0", "citation_url": "https://suttacentral.net/an6.55/en/sujato", "fetch_url": "https://suttacentral.net/an6.55/en/sujato", "verified_date": "2026-05-08", "quote": "Their mind is quite untainted. It is steady, imperturbable, observing disappearance.", "turn_idx": 15}
