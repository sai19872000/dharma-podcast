{"episode": "ep001-vairagya", "quote_id": 1, "tradition": "east-lineage", "work": "Bhagavad Gita 2.47–2.48 (The Song Celestial)", "translator": "Edwin Arnold", "verse_or_section": "2.47–2.48", "license": "PD", "citation_url": "https://www.sacred-texts.com/hin/gita/bg02.htm", "fetch_url": "https://www.sacred-texts.com/hin/gita/bg02.htm", "verified_date": "2026-05-08", "quote": "Let right deeds be thy motive, not the fruit which comes from them. And live in action! Labour! Make thine acts thy piety, casting all self aside, contemning gain and merit; equable in good or evil: equability is Yog, is piety!", "turn_idx": 1}
{"episode": "ep001-vairagya", "quote_id": 2, "tradition": "east-lineage", "work": "Yoga Sūtras 1.15 (Raja Yoga)", "translator": "Swami Vivekananda", "verse_or_section": "1.15", "license": "PD", "citation_url": "https://www.sacred-texts.com/hin/yogasutr.htm", "fetch_url": "https://www.sacred-texts.com/hin/yogasutr.htm", "verified_date": "2026-05-08", "quote": "given up their thirst after objects, either seen or heard", "turn_idx": 3}
{"episode": "ep001-vairagya", "quote_id": 3, "tradition": "east-lineage", "work": "Bhagavad Gita 2.56 (The Song Celestial)", "translator": "Edwin Arnold", "verse_or_section": "2.56", "license": "PD", "citation_url": "https://www.sacred-texts.com/hin/gita/bg02.htm", "fetch_url": "https://www.sacred-texts.com/hin/gita/bg02.htm", "verified_date": "2026-05-08", "quote": "In sorrows not dejected, and in joys not overjoyed; dwelling outside the stress of passion, fear, and anger; fixed in calms of lofty contemplation.", "turn_idx": 9}
{"episode": "ep001-vairagya", "quote_id": 4, "tradition": "east-lineage", "work": "Anguttara Nikāya 5.30 — With Nāgita", "translator": "Bhante Sujato", "verse_or_section": "AN 5.30", "license": "CC0", "citation_url": "https://suttacentral.net/an5.30/en/sujato", "fetch_url": "https://suttacentral.net/an5.30/en/sujato", "verified_date": "2026-05-08", "quote": "What you eat, drink, chew, and taste ends up as excrement and urine. This is its outcome.", "turn_idx": 11}
